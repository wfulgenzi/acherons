# Copy to .env.test.local (gitignored) and adjust if needed.
# Use only for integration tests + db:test:* scripts.
#
# After `yarn db:test:up`, run: yarn db:test:prepare (wait + migrate + grant)

# RLS-enforced app role (not the table owner — use for withRLS + db in tests)
DATABASE_URL=postgresql://acherons_app:acherons_app_test@127.0.0.1:55432/acherons_test

# Superuser: migrations + truncate + seed in tests
DATABASE_ADMIN_URL=postgresql://postgres:postgres@127.0.0.1:55432/acherons_test
